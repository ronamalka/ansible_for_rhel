<?xml version="1.0" encoding="UTF-8"?>
<xccdf:Tailoring xmlns:xccdf="http://checklists.nist.gov/xccdf/1.2"
                 id="xccdf_org_tailoring_cis_workshop">
  <xccdf:benchmark href="/usr/share/xml/scap/ssg/content/ssg-rhel8-ds.xml"
                   id="xccdf_org.ssgproject.content_benchmark_RHEL-8"/>
  <xccdf:version time="2026-07-12T00:00:00">1</xccdf:version>
  <xccdf:Profile id="xccdf_org.ssgproject.content_profile_cis_workshop"
                 extends="xccdf_org.ssgproject.content_profile_cis">
    <xccdf:title>CIS Demo - Auto-Remediable Controls</xccdf:title>
    <xccdf:description>
      Workshop demo profile derived from CIS Level 2 Server. Excludes rules
      that require disk reprovisioning, GRUB passwords, root password policy,
      or passwordless sudo removal (Ansible needs NOPASSWD for ec2-user).
    </xccdf:description>
    <!-- Disk layout: cannot be auto-remediated on running VMs -->
    <xccdf:select idref="xccdf_org.ssgproject.content_rule_partition_for_home" selected="false"/>
    <xccdf:select idref="xccdf_org.ssgproject.content_rule_partition_for_tmp" selected="false"/>
    <xccdf:select idref="xccdf_org.ssgproject.content_rule_partition_for_var" selected="false"/>
    <xccdf:select idref="xccdf_org.ssgproject.content_rule_partition_for_var_log" selected="false"/>
    <xccdf:select idref="xccdf_org.ssgproject.content_rule_partition_for_var_log_audit" selected="false"/>
    <xccdf:select idref="xccdf_org.ssgproject.content_rule_partition_for_var_tmp" selected="false"/>
    <!-- Manual / interactive controls -->
    <xccdf:select idref="xccdf_org.ssgproject.content_rule_grub2_password" selected="false"/>
    <xccdf:select idref="xccdf_org.ssgproject.content_rule_ensure_root_password_configured" selected="false"/>
    <!-- Workshop: preserve passwordless sudo for Ansible -->
    <xccdf:select idref="xccdf_org.ssgproject.content_rule_sudo_require_authentication" selected="false"/>
    <!-- Often manual / environment-specific -->
    <xccdf:select idref="xccdf_org.ssgproject.content_rule_sshd_limit_user_access" selected="false"/>
    <xccdf:select idref="xccdf_org.ssgproject.content_rule_selinux_confinement_of_daemons" selected="false"/>
  </xccdf:Profile>
</xccdf:Tailoring>
